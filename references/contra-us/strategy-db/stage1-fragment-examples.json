  "fragments": [
    {
      "id": "stage1-w1110-1160-reward-station-falling-soldier",
      "label": "WorldX 1110-1160 reward station falling soldier survival",
      "status": "candidate",
      "strategyTypes": [
        "survival",
        "combat",
        "loot",
        "guard"
      ],
      "worldWindow": {
        "start": 1110,
        "end": 1160,
        "strictEnd": true
      },
      "trigger": {
        "mode": "all",
        "conditions": [
          {
            "field": "ram.level",
            "op": "eq",
            "value": 0,
            "note": "Contra stage 1 in current runtime uses level index 0."
          },
          {
            "field": "ram.worldX",
            "op": "between",
            "value": [
              1110,
              1160
            ],
            "note": "Local failure was observed around WorldX 1132."
          },
          {
            "field": "ram.playerY",
            "op": "gte",
            "value": 188,
            "note": "Low route posture; the documented death was in the lower lane."
          }
        ]
      },
      "ramConditions": [
        {
          "field": "threatPool.dynamicThreats",
          "op": "count-gte",
          "value": 1,
          "note": "At least one non-fixed active enemy threat is near the player."
        },
        {
          "field": "enemy.nearestDynamic.dx",
          "op": "between",
          "value": [
            -8,
            48
          ],
          "note": "Equivalent to the current falling-threat detector around playerX."
        },
        {
          "field": "enemy.nearestDynamic.dy",
          "op": "between",
          "value": [
            -112,
            -16
          ],
          "note": "Falling or upper-body enemy descending into contact range."
        },
        {
          "field": "horizon.rewardAhead.category",
          "op": "eq",
          "value": "reward",
          "note": "Reward intent is present, but survival must dominate collection."
        }
      ],
      "actionAdvice": {
        "intent": "survive",
        "priority": 130,
        "buttons": {
          "a": false,
          "b": "pulse",
          "up": "target",
          "down": false,
          "left": false,
          "right": "preserve"
        },
        "aim": "target",
        "fireMode": "target",
        "movementPolicy": "hold-ground",
        "lockFrames": 10,
        "notes": "Do not convert this into a blind jump. Keep firing at the falling soldier, pause or slow horizontal progress if current fire cannot neutralize the threat."
      },
      "safetyOverrides": [
        {
          "id": "falling-soldier-contact-guard",
          "priority": 210,
          "when": [
            {
              "field": "enemy.nearestDynamic.dx",
              "op": "between",
              "value": [
                -4,
                28
              ],
              "note": "Body contact corridor."
            },
            {
              "field": "enemy.nearestDynamic.dy",
              "op": "between",
              "value": [
                -44,
                6
              ],
              "note": "Enemy is about to overlap the player."
            }
          ],
          "override": {
            "a": false,
            "b": true,
            "right": false,
            "left": false
          },
          "reason": "Near body contact is more important than reward aim or route speed."
        },
        {
          "id": "projectile-emergency-keeps-existing-danger-layer",
          "priority": 240,
          "when": [
            {
              "field": "threatPool.projectiles",
              "op": "count-gte",
              "value": 1,
              "note": "Runtime Danger Layer remains higher priority than this fragment."
            }
          ],
          "override": {
            "a": "preserve",
            "b": "preserve",
            "left": "preserve",
            "right": "preserve"
          },
          "reason": "Fragment data must not mask immediate projectile survival."
        }
      ],
      "exitConditions": [
        {
          "field": "ram.worldX",
          "op": "gt",
          "value": 1160,
          "note": "Normal progress out of local fragment."
        },
        {
          "field": "enemy.nearestDynamic.exists",
          "op": "eq",
          "value": false,
          "note": "Falling body threat no longer exists."
        },
        {
          "field": "ram.deathFlag",
          "op": "neq",
          "value": 0,
          "note": "Failure exit for death trace capture."
        }
      ],
      "failureCounterexamples": [
        {
          "id": "w1132-falling-soldier-death",
          "observedAt": {
            "worldX": 1132,
            "playerX": 119,
            "playerY": 212
          },
          "description": "AI died to a falling or upper-lane soldier while reward and fixed-fire logic were active.",
          "avoid": [
            "Do not keep pure rightward advance when a falling soldier is within body-contact corridor.",
            "Do not prefer reward collection over same-lane survival.",
            "Do not add blind jump patches in this low-route window without proof; prior low-route micro patches became worse."
          ],
          "evidence": [
            "Existing test covers findRewardStationFallingThreat at worldX 1132 with playerX 119 and playerY 212.",
            "Strategy requirements doc records the first bridge after-death zone around WorldX 1180-1240 and states the issue is route selection before the low-route death zone."
          ]
        }
      ],
      "telemetry": {
        "requiredFields": [
          "frame",
          "ram.worldX",
          "ram.playerX",
          "ram.playerY",
          "ram.jumpState",
          "ram.weapon",
          "enemySlots",
          "threatPool",
          "horizon.primary",
          "routeSegment",
          "rawAiInput",
          "lockedAiInput",
          "deathTrace"
        ],
        "successSignals": [
          {
            "field": "ram.worldX",
            "op": "gt",
            "value": 1160,
            "note": "Fragment cleared without death."
          },
          {
            "field": "metrics.deathsDelta",
            "op": "eq",
            "value": 0,
            "note": "No death during or immediately after the fragment."
          }
        ],
        "debugTags": [
          "fragment:w1110-1160",
          "threat:falling-soldier",
          "objective:survival-over-reward"
        ]
      }
