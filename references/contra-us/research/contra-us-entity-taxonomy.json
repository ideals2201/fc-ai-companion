  "classification_rules": {
    "enemy_type_scope": "Types 0x00-0x0f are shared; types 0x10 and above are level-specific and must be interpreted with current level context.",
    "outdoor_spawn_record": {
      "format": "XX TT YY plus repeat bytes",
      "byte_0": "x_offset",
      "byte_1_high_2_bits": "repeat_count",
      "byte_1_low_6_bits": "enemy_type",
      "byte_2_high_5_bits": "y_offset",
      "byte_2_low_3_bits": "attribute"
    },
    "property_record": {
      "size_bytes": 4,
      "byte_0": "enemy_state_width",
      "byte_1": "enemy_score_collision",
      "byte_1_high_nibble": "score_code",
      "byte_1_low_nibble": "collision_code",
      "byte_2": "enemy_hp",
      "byte_3": "enemy_var_a"
    },
    "hp_caveat": "Static hp from enemy_prop tables is not always effective real HP; invulnerability values 0xf0/0xf1 and several bosses require routine-specific interpretation."
  },
