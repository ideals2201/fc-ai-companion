  "strategyDescriptions": {
    "survival-v0": {
      "label": "Robust Survival",
      "summary": "Prioritizes staying alive, slows progression when needed, and clears required fixed threats and blockers.",
      "playStyle": "Suitable for single-AI clear attempts, human-AI companion play, and dual-AI stability baselines.",
      "riskPolicy": "Safety override takes priority over speed, rewards, and kill count.",
      "dataSource": "quality.strategyResults + stages/<stage-id>/training-progress.json",
      "localization": {
        "zh-CN": {
          "label": "稳健生存",
          "summary": "优先保证不死，必要时放慢推进，先处理固定威胁和必过障碍。",
          "playStyle": "适合单 AI 通关、人类加 AI 陪玩、双 AI 稳定基准。",
          "riskPolicy": "安全覆盖优先于速度、奖励和杀敌数量。"
        }
      }
    },
    "speedrun-v0": {
      "label": "Fast Advance",
      "summary": "Prioritizes forward pace and reusable TAS/FCEUX windows while preserving safety override.",
      "playStyle": "Suitable for showcase runs, speed training, and later clear-time optimization.",
      "riskPolicy": "May skip nonessential kills and rewards, but must not violate required survival conditions.",
      "dataSource": "quality.strategyResults + stages/<stage-id>/training-progress.json",
      "localization": {
        "zh-CN": {
          "label": "快速推进",
          "summary": "优先推进速度，复用 TAS/FCEUX 可用窗口，但必须保留安全覆盖。",
          "playStyle": "适合观赏、竞速训练和后续优化过关时间。",
          "riskPolicy": "允许减少非必要清敌和奖励，但不能牺牲必需生存条件。"
        }
      }
    },
    "combat-v0": {
      "label": "Combat Clear",
      "summary": "Prioritizes killing enemies, turrets, and fixed targets to reduce screen threat density.",
      "playStyle": "Suitable for cautious combat, result farming, and threat-handling research.",
      "riskPolicy": "May slow down to clear threats, but must not enter dead loops or die for optional kills.",
      "dataSource": "quality.strategyResults + stages/<stage-id>/training-progress.json",
      "localization": {
        "zh-CN": {
          "label": "清敌优先",
          "summary": "优先消灭敌人、炮台和固定目标，降低屏幕威胁密度。",
          "playStyle": "适合稳扎稳打、刷战果和研究威胁处理。",
          "riskPolicy": "可以放慢推进等待清场，但不能进入死循环或为清敌主动送死。"
        }
      }
    },
    "loot-v0": {
      "label": "Loot Priority",
      "summary": "Prioritizes weapons, reward capsules, and key resources when safety permits route adjustment.",
      "playStyle": "Suitable for collection routes, weapon optimization, and reward-focused viewing.",
      "riskPolicy": "Rewards are subordinate to survival and must not break clear stability.",
      "dataSource": "quality.strategyResults + stages/<stage-id>/training-progress.json",
      "localization": {
        "zh-CN": {
          "label": "奖励优先",
          "summary": "优先获取武器、奖励胶囊和关键资源，在安全允许时调整路线。",
          "playStyle": "适合收集路线、武器优化和玩家观赏奖励获取。",
          "riskPolicy": "奖励必须服从生存，不能为了吃奖励破坏通关稳定性。"
        }
      }
    },
    "guard-v0": {
      "label": "Companion Guard",
      "summary": "Provides cover fire, anti-screen-drag behavior, and cooperative progression around the teammate.",
      "playStyle": "Suitable for human-AI companion play and dual-AI cooperation.",
      "riskPolicy": "Prioritizes teammate safety and screen tempo, avoiding screen drag and dangerous reward steals.",
      "dataSource": "quality.strategyResults + stages/<stage-id>/training-progress.json",
      "localization": {
        "zh-CN": {
          "label": "护卫队友",
          "summary": "围绕队友位置提供火力、防拖屏和协作推进。",
          "playStyle": "适合人类加 AI 陪玩和双 AI 协作。",
          "riskPolicy": "优先保护队友和屏幕节奏，不抢屏、不抢危险奖励。"
        }
      }
    }
