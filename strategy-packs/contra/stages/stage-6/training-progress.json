  "strategyDescriptions": {
    "survival-v0": {
      "label": "Robust Survival",
      "summary": "Prioritizes zero-death progression, safety override, fixed-threat handling, and stable clear routing.",
      "playStyle": "Single-AI clear baseline and parent route for all other strategy types.",
      "riskPolicy": "Safety, pits, body contact, and fixed-threat survival override speed, reward, and kill objectives.",
      "dataSource": "stages/<stage-id>/training-progress.json + contra-j-good runtime evidence"
    },
    "speedrun-v0": {
      "label": "Fast Advance",
      "summary": "Optimizes clear time after survival windows are stable.",
      "playStyle": "Showcase and speed route training.",
      "riskPolicy": "May skip optional kills and rewards, but cannot violate survival gates inherited from survival-v0.",
      "dataSource": "stages/<stage-id>/training-progress.json + TAS baseline candidates"
    },
    "combat-v0": {
      "label": "Combat Clear",
      "summary": "Prioritizes enemy, turret, and fixed-target destruction while preserving clear stability.",
      "playStyle": "Threat-density reduction, kill-count farming, and safer human-facing companion play.",
      "riskPolicy": "Optional kills must not create dead loops or increase death probability beyond survival guardrails.",
      "dataSource": "stages/<stage-id>/training-progress.json + trace-evidence combat chain"
    },
    "loot-v0": {
      "label": "Loot Priority",
      "summary": "Prioritizes weapon and reward capture after survival windows are stable.",
      "playStyle": "Weapon optimization, reward viewing, and resource-rich companion play.",
      "riskPolicy": "Rewards are subordinate to survival and validated route continuity.",
      "dataSource": "stages/<stage-id>/training-progress.json + TAS/human pickup windows"
    },
    "guard-v0": {
      "label": "Companion Guard",
      "summary": "Prioritizes teammate safety, screen pacing, cover fire, and anti-screen-drag behavior.",
      "playStyle": "Human + AI and dual-AI cooperative play.",
      "riskPolicy": "Never steal dangerous rewards or drag the screen in a way that harms the teammate.",
      "dataSource": "stages/<stage-id>/training-progress.json + 2P/TAS cooperation evidence"
    }
  }
