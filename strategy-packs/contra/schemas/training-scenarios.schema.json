{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fc-ai.local/schemas/training-scenarios-1.0.0.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "gameProfileId",
    "scenarios"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "gameProfileId": {
      "type": "string",
      "minLength": 1
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "scenarioId",
          "status",
          "romProfileIds",
          "stageId",
          "mode",
          "strategyTypes",
          "variableRefs",
          "rewardRules",
          "terminalConditions",
          "failureConditions",
          "evidenceRequirements"
        ],
        "properties": {
          "scenarioId": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "draft",
              "candidate",
              "validated",
              "retired"
            ]
          },
          "romProfileIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "stageId": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "minLength": 1
          },
          "strategyTypes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "variableRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "ref",
                "role",
                "required"
              ],
              "properties": {
                "ref": {
                  "type": "string",
                  "minLength": 1
                },
                "role": {
                  "type": "string",
                  "minLength": 1
                },
                "required": {
                  "type": "boolean"
                }
              },
              "additionalProperties": true
            }
          },
          "rewardRules": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "ref",
                "op",
                "weight"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "ref": {
                  "type": "string",
                  "minLength": 1
                },
                "op": {
                  "type": "string",
                  "minLength": 1
                },
                "weight": {
                  "type": "number"
                }
              },
              "additionalProperties": true
            }
          },
          "terminalConditions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/condition"
            }
          },
          "failureConditions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/condition"
            }
          },
          "evidenceRequirements": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "condition": {
      "type": "object",
      "required": [
        "id",
        "ref",
        "op"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "op": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
