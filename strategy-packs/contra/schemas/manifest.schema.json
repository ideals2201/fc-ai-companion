{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fc-ai.local/schemas/strategy-pack-manifest-1.0.0.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "packId",
    "packVersion",
    "author",
    "provenance",
    "gameProfileId",
    "romProfileIds",
    "strategyKeys",
    "supportedModes",
    "status",
    "standards",
    "files",
    "quality"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "packId": { "type": "string", "minLength": 1 },
    "packVersion": { "type": "string", "minLength": 1 },
    "author": {
      "type": "object",
      "required": ["displayName"],
      "properties": {
        "displayName": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "required": ["creator", "latestModifier", "revisions"],
      "properties": {
        "creator": { "$ref": "#/$defs/contributor" },
        "latestModifier": { "$ref": "#/$defs/contributor" },
        "revisions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "revisionId",
              "version",
              "modifiedBy",
              "modifiedAt",
              "summary",
              "changeType",
              "validationStatus",
              "hash",
              "snapshotPath"
            ],
            "properties": {
              "revisionId": { "type": "string", "minLength": 1 },
              "version": { "type": "string", "minLength": 1 },
              "modifiedBy": { "$ref": "#/$defs/contributor" },
              "modifiedAt": { "type": "string", "minLength": 1 },
              "summary": { "type": "string", "minLength": 1 },
              "changeType": { "type": "string", "minLength": 1 },
              "validationStatus": { "type": "string", "minLength": 1 },
              "hash": { "type": ["string", "null"] },
              "parentHash": { "type": ["string", "null"] },
              "snapshotPath": { "type": ["string", "null"] }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "identity": {
      "type": "object",
      "properties": {
        "trainingWindowName": { "type": "string", "minLength": 1 },
        "avatarAsset": {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "minLength": 1 },
            "preset": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "gameProfileId": { "type": "string", "minLength": 1 },
    "romProfileIds": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "strategyKeys": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "supportedModes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "status": {
      "enum": [
        "draft",
        "candidate",
        "validated-single-ai",
        "validated-human-ai",
        "validated-dual-ai",
        "retired"
      ]
    },
    "standards": { "type": "object" },
    "files": { "type": "object" },
    "quality": {
      "type": "object",
      "properties": {
        "strategyResults": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["status", "metrics"],
            "properties": {
              "status": { "type": "string", "minLength": 1 },
              "evidence": { "type": "string" },
              "metrics": {
                "type": "object",
                "required": [
                  "kills",
                  "fixedTargetsDestroyed",
                  "rewardsCollected",
                  "clearTimeFrames"
                ],
                "properties": {
                  "kills": { "$ref": "#/$defs/resultMetric" },
                  "fixedTargetsDestroyed": { "$ref": "#/$defs/resultMetric" },
                  "rewardsCollected": { "$ref": "#/$defs/resultMetric" },
                  "clearTimeFrames": { "$ref": "#/$defs/resultMetric" }
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "contributor": {
      "type": "object",
      "required": ["displayName"],
      "properties": {
        "displayName": { "type": "string", "minLength": 1 },
        "role": { "type": "string" }
      },
      "additionalProperties": true
    },
    "resultMetric": {
      "type": "object",
      "required": ["value", "status"],
      "properties": {
        "value": { "type": ["number", "null"] },
        "status": {
          "enum": ["unverified", "measured", "validated"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
