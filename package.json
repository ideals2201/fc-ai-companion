{
  "name": "fc-ai-companion",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-based FC/NES AI companion cockpit.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:cockpit": "npm run dev --workspace @fc-ai/browser-cockpit",
    "build": "npm run build --workspace @fc-ai/browser-cockpit",
    "build:tas-side-baselines": "node scripts/build-tas-side-baselines.mjs",
    "sync:strategies": "node scripts/sync-strategy-packs.mjs",
    "test": "node --test tests/*.test.mjs",
    "check": "npm test && npm run build"
  },
  "license": "UNLICENSED"
}
